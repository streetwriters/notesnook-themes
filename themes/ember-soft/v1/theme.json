      "disabled": {
        "hover": "#242320"
      },
      "selected": {
        "background": "#35332f",
        "hover": "#3d3b37"
      }
    },
    "editor": {
      "primary": {
        "background": "#242320",
        "border": "#2c2a26"
      },
      "secondary": {
        "paragraph": "#8a8477",
        "background": "#2c2a26",
        "border": "#35332f"
      }
    },
    "editorToolbar": {
      "primary": {
        "background": "#242320",
        "hover": "#2c2a26"
      },
      "secondary": {
        "background": "#2c2a26"
      }
    },
    "navigationMenu": {
      "primary": {
        "background": "#242320"
      }
    },
    "contextMenu": {
      "primary": {
        "background": "#2c2a26"
      }
    },
    "sheet": {
      "selected": {
        "paragraph": "#8a9868"
      }
    }
  }
